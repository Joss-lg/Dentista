---
import { Image } from 'astro:assets';
import limpiaImg from '../assets/imagenes/limpia.jpg';
import blanqueaImg from '../assets/imagenes/blanqueamiento.jpg';
import ortoImg from '../assets/imagenes/ortodoncia.jpg';
import implanteImg from '../assets/imagenes/implantes.jpg';
import visa from '../assets/imagenes/visa.jpg';
import mastercard from '../assets/imagenes/mastercard.jpg';

const servicios = [
  { title: "Limpieza Profesional", img: limpiaImg, desc: "Salud impecable con tecnología ultrasónica.", precio: "Precio $500" },
  { title: "Blanqueamiento Estético", img: blanqueaImg, desc: "Brillo natural en una sola sesión.", precio: "Precio $2,500 - $5,000" },
  { title: "Ortodoncia Invisible", img: ortoImg, desc: "Alineación perfecta sin que se note.", precio: "Desde $7,000" },
  { title: "Implantes Dentales", img: implanteImg, desc: "Restauraciones fijas con acabado natural.", precio: "Desde $10,000" }
];
---

<section id="servicios" class="py-6 px-3 md:px-8 max-w-7xl mx-auto scroll-mt-6">
  <div class="text-center mb-16 reveal">
    <h2 class="text-4xl md:text-6xl font-black text-slate-900 mb-4 tracking-tight">
      Servicios <span class="text-cyan-500">Disponibles</span>
    </h2>
    <div class="h-1.5 w-24 bg-cyan-400 mx-auto rounded-full shadow-[0_0_15px_rgba(34,211,238,0.5)]"></div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
    {servicios.map((s) => (
      /* Cada tarjeta tiene la clase 'reveal' para que tu script de index la detecte */
      <article class="reveal flex flex-col bg-white rounded-[2.5rem] overflow-hidden border border-slate-200 shadow-sm transition-all duration-500 hover:shadow-2xl hover:-translate-y-4 group">
        
        <div class="relative h-52 overflow-hidden">
          <Image 
            src={s.img} 
            alt={s.title} 
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900/40 to-transparent"></div>
        </div>

        <div class="p-8 flex flex-col flex-grow">
          <div class="flex-grow">
            <h3 class="text-xl font-bold text-slate-800 group-hover:text-cyan-500 transition-colors">
              {s.title}
            </h3>
            <p class="text-slate-500 text-sm mt-2 italic leading-relaxed">
              {s.desc}
            </p>
          </div>

          <div class="mt-8 pt-6 border-t border-slate-100">
            <p class="text-center text-emerald-600 font-black text-sm mb-6 bg-emerald-50 py-2 rounded-full">
              {s.precio}
            </p>
            
            <div class="flex flex-col items-center gap-3">
              <div class="flex justify-center items-center gap-4 opacity-80 grayscale group-hover:grayscale-0 transition-all duration-500">
                <Image src={visa} alt="Visa" width={40} height={25} class="h-5 w-auto object-contain" />
                <Image src={mastercard} alt="Mastercard" width={40} height={25} class="h-7 w-auto object-contain" />
              </div>
              <span class="text-[9px] uppercase tracking-[0.2em] text-slate-400 font-bold">
                Aceptamos tarjetas
              </span>
            </div>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>