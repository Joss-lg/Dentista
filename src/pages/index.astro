---
import Layout from '../layouts/Layout.astro';
import Port from '../components/Portada.astro';
import Servicio from '../components/Servicios.astro';
import Equip from '../components/Equipo.astro';
import Contact from '../components/Contacto.astro';
import Whatsapp from '../components/Whatsapp.astro';
import Resenas from '../components/Reseñas.astro'
import Procesos from '../components/Procesos.astro';
import Ubicacion from '../components/Ubicacion.astro';
---

<Layout title="Inicio | Clínica Dental Sonrisa">
  <Port />
  
  <main class="bg-white">
    <Servicio />
    <Equip />
    
    <section class="reveal py-24 bg-gradient-to-br from-cyan-500 to-blue-600 text-white text-center px-6 shadow-inner">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl md:text-5xl font-black mb-4 italic tracking-tight">"Excelencia y Confianza"</h2>
        <p class="text-xl opacity-90 font-light">Más de 10 años transformando sonrisas en México.</p>
      </div>
    </section>

    <Contact />
    <Ubicacion/>
    <Resenas/>
    <Procesos/>
  </main>

  <footer class="py-12 bg-slate-950 text-slate-500 text-center border-t border-slate-900">
    <p>© 2026 Clínica Dental Sonrisa • Diseñado para brillar</p>
  </footer>

  <Whatsapp/>
</Layout>

<script>
  const observerOptions = { threshold: 0.15 };
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('active');
    });
  }, observerOptions);
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;

  html { scroll-behavior: smooth; }
  .reveal { opacity: 0; transform: translateY(30px); transition: all 0.8s ease-out; }
  .reveal.active { opacity: 1; transform: translateY(0); }
  .text-gradient { @apply bg-clip-text text-transparent bg-gradient-to-r from-cyan-400 to-blue-400; }
  .btn-primary, .btn-secondary { @apply bg-cyan-400 hover:bg-cyan-300 text-slate-900 px-8 py-4 rounded-full font-black transition-all transform hover:scale-105 active:scale-95; }
  .btn-three, .btn-four { @apply bg-white/10 hover:bg-white/20 backdrop-blur-md border border-white/30 text-white px-8 py-4 rounded-full font-black transition-all transform hover:scale-105 active:scale-95; }
  .form-input { @apply w-full px-6 py-4 rounded-2xl bg-slate-50 border-transparent focus:bg-white focus:border-cyan-400 focus:ring-4 focus:ring-cyan-50 focus:outline-none transition-all; }
  
  @keyframes slow-zoom {
    from { transform: scale(1); }
    to { transform: scale(1.1); }
  }
  .animate-slow-zoom { animation: slow-zoom 20s infinite alternate ease-in-out; }
</style>