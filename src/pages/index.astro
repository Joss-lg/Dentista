---
// src/pages/index.astro
// Aquí puedes importar componentes si los tuvieras
const clinicName = "Sonrisa Vital";
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{clinicName} - Cuidado Dental Profesional</title>
	</head>
	<body class="bg-slate-50 text-slate-900 font-sans">
		
		<main class="min-h-screen flex flex-col justify-center items-center px-6">
			<div class="max-w-4xl text-center">
				<span class="inline-block px-4 py-1.5 mb-6 text-sm font-semibold tracking-wide text-blue-600 uppercase bg-blue-100 rounded-full">
					Próximamente
				</span>
				
				<h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-slate-900 mb-6">
					Tu sonrisa en las mejores <span class="text-blue-600 italic">manos.</span>
				</h1>
				
				<p class="text-lg md:text-xl text-slate-600 mb-10 max-w-2xl mx-auto">
					Estamos preparando un espacio digital para que agendar tu cita y cuidar tu salud bucal sea más fácil que nunca.
				</p>
				
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a href="#" class="px-8 py-4 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 transition-all shadow-lg shadow-blue-200">
						Agendar Cita
					</a>
					<a href="#" class="px-8 py-4 bg-white text-slate-700 font-bold border border-slate-200 rounded-xl hover:bg-slate-50 transition-all">
						Ver Servicios
					</a>
				</div>
			</div>

			<footer class="absolute bottom-8 text-slate-400 text-sm">
				&copy; {new Date().getFullYear()} {clinicName}. Todos los derechos reservados.
			</footer>
		</main>

	</body>
</html>